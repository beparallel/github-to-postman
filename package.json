{
  "name": "@parallel/github-to-postman",
  "version": "0.0.6",
  "private": true,
  "description": "Sync Postman collections from GitHub",
  "packageManager": "pnpm@10.1.0",
  "main": "lib/main.js",
  "scripts": {
    "bundle": "pnpm run format:write && pnpm run package",
    "format:write": "pnpm prettier --write .",
    "format:check": "pnpm prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "package": "rollup -c rollup.config.mjs",
    "package:watch": "rollup -c rollup.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync-local": "tsx src/cli.ts",
    "all": "pnpm run format:write && pnpm run package",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "axios": "^1.15.2",
    "octokit": "^5.0.5",
    "openapi-to-postmanv2": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
